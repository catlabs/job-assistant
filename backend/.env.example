# Local-friendly example values. For a first production-like deployment,
# keep the same variable names but change the values below as needed.
JOB_ASSISTANT_APP_NAME=Job Assistant API
JOB_ASSISTANT_API_VERSION=0.1.0
# Set to false in production.
JOB_ASSISTANT_DEBUG=false
# Keep 127.0.0.1 for local-only access. Use 0.0.0.0 when the backend must
# accept remote traffic directly or from a container/network bridge.
JOB_ASSISTANT_HOST=127.0.0.1
JOB_ASSISTANT_PORT=8000
# Use a persistent absolute path in production, for example:
# sqlite:////var/lib/job-assistant/job_assistant.db
JOB_ASSISTANT_DATABASE_URL=sqlite:///./job_assistant.db
# Optional, but recommended for internet-exposed deployments.
JOB_ASSISTANT_API_KEY=
# Comma-separated list. This must match the deployed frontend origin(s).
JOB_ASSISTANT_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Required for LLM-backed features such as field extraction and profile explain.
JOB_ASSISTANT_OPENAI_API_KEY=
JOB_ASSISTANT_OPENAI_MODEL=gpt-4.1-mini
JOB_ASSISTANT_OPENAI_TIMEOUT_SECONDS=20
